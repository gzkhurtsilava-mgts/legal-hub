# ===========================
# Legal Hub — конфигурация
# Скопируйте в .env и заполните
# ===========================

# Приложение
APP_ENV=development
SECRET_KEY=замените-на-случайную-строку-минимум-32-символа

# База данных
POSTGRES_DB=legalhub
POSTGRES_USER=legalhub
POSTGRES_PASSWORD=legalhub_dev

# Redis
REDIS_URL=redis://redis:6379

# CORS — адреса откуда разрешены запросы к API
CORS_ORIGINS=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# Почта (заполнить позже)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=legal-portal@mgts.ru

# SSO (заполнить когда дадут провайдер)
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_DISCOVERY_URL=
