{
    "name":  "@mts-ds/granat2-react-toast",
    "version":  "1.0.0",
    "homepage":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds",
    "bugs":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds/-/issues",
    "repository":  {
                       "type":  "git",
                       "url":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds.git"
                   },
    "type":  "module",
    "main":  "./dist/esm-node-14/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "node":  {
                                           "import":  "./dist/esm-node-14/index.js",
                                           "default":  "./dist/esm-node-14/index.js"
                                       },
                              "default":  "./dist/esm/index.js"
                          },
                    "./severed":  {
                                      "types":  "./dist/index.d.ts",
                                      "node":  {
                                                   "import":  "./dist/esm-node-14-severed/index.js",
                                                   "default":  "./dist/esm-node-14-severed/index.js"
                                               },
                                      "default":  "./dist/esm-severed/index.js"
                                  },
                    "./severed/bundle.css":  "./dist/bundle.css",
                    "./package.json":  "./package.json"
                },
    "typesVersions":  {
                          "*":  {
                                    "severed":  [
                                                    "./dist/index.d.ts"
                                                ]
                                }
                      },
    "files":  [
                  "dist/",
                  "./*.md"
              ],
    "sideEffects":  [
                        "*.css",
                        "*.scss",
                        "*.css.js"
                    ],
    "scripts":  {
                    "build":  "yarn react-component2:build",
                    "watch":  "yarn react-component2:watch",
                    "tsc":  "yarn react-component2:tsc"
                },
    "dependencies":  {
                         "clsx":  "^1.2.1"
                     },
    "devDependencies":  {
                            "@types/react":  "^17.0.39",
                            "@types/react-dom":  "^17.0.11",
                            "react":  "^17.0.2",
                            "react-dom":  "^17.0.2",
                            "typescript":  "~4.7.3"
                        },
    "peerDependencies":  {
                             "react":  "^16.14.0 || 17.x || 18.x",
                             "react-dom":  "^16.14.0 || 17.x || 18.x"
                         }
}