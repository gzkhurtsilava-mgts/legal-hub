{
    "name":  "@mts-ds/react-utils",
    "version":  "1.3.0",
    "homepage":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds",
    "bugs":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds/-/issues",
    "repository":  {
                       "type":  "git",
                       "url":  "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds.git"
                   },
    "type":  "module",
    "main":  "./dist/esm-node-14/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "node":  {
                                           "import":  "./dist/esm-node-14/index.js",
                                           "default":  "./dist/esm-node-14/index.js"
                                       },
                              "default":  "./dist/esm/index.js"
                          },
                    "./package.json":  "./package.json"
                },
    "sideEffects":  false,
    "files":  [
                  "dist/",
                  "./*.md"
              ],
    "scripts":  {
                    "build":  "yarn react-component:build-utils",
                    "watch":  "yarn react-component:watch",
                    "tsc":  "yarn react-component:tsc",
                    "lint":  "NODE_OPTIONS=\"--max-old-space-size=4096\" eslint ./src",
                    "clean":  "npx rimraf dist",
                    "test":  "jest"
                },
    "devDependencies":  {
                            "@types/jest":  "^28.1.2",
                            "@types/node":  "^17.0.40",
                            "@types/react":  "^17.0.39",
                            "@types/react-dom":  "^17.0.11",
                            "@typescript-eslint/eslint-plugin":  "^5.27.1",
                            "@typescript-eslint/parser":  "^5.54.1",
                            "clsx":  "^1.2.1",
                            "eslint":  "^8.17.0",
                            "eslint-config-airbnb":  "^19.0.4",
                            "eslint-config-airbnb-typescript":  "^17.0.0",
                            "eslint-config-prettier":  "^8.5.0",
                            "eslint-import-resolver-typescript":  "^3.5.3",
                            "eslint-plugin-eslint-comments":  "^3.2.0",
                            "eslint-plugin-import":  "^2.26.0",
                            "eslint-plugin-jest":  "^26.5.3",
                            "eslint-plugin-jsx-a11y":  "^6.5.1",
                            "eslint-plugin-promise":  "^6.0.0",
                            "eslint-plugin-react":  "^7.30.0",
                            "eslint-plugin-react-hooks":  "^4.5.0",
                            "eslint-plugin-unicorn":  "^42.0.0",
                            "jest":  "^28.1.1",
                            "jest-cli":  "^28.1.1",
                            "prettier":  "^2.7.1",
                            "react":  "^17.0.2",
                            "react-dom":  "^17.0.2",
                            "rimraf":  "^3.0.2",
                            "typescript":  "~4.7.3"
                        },
    "peerDependencies":  {
                             "react":  "^16.14.0 || 17.x || 18.x",
                             "react-dom":  "^16.14.0 || 17.x || 18.x"
                         }
}