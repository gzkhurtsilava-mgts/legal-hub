{
  "name": "@mts-ds/granat2-react-theme",
  "version": "1.0.1",
  "homepage": "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds",
  "bugs": "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds/-/issues",
  "repository": {
    "type": "git",
    "url": "https://gitlab.services.mts.ru/mobile-sdk/web/mtsds.git"
  },
  "type": "module",
  "main": "./dist/esm-node-14/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/esm-node-14/index.js",
        "default": "./dist/esm-node-14/index.js"
      },
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "*.md"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "build": "yarn react-component2:build-utils",
    "watch": "yarn react-component2:watch",
    "tsc": "yarn react-component2:tsc"
  },
  "dependencies": {
    "@mts-ds/react-utils": "^1.1.0"
  },
  "devDependencies": {
    "@mts-ds/react-utils": "^1.2.0",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "~4.7.3"
  },
  "peerDependencies": {
    "@mts-ds/granat2-react-root": "^2.0.0",
    "react": "^16.14.0 || 17.x || 18.x",
    "react-dom": "^16.14.0 || 17.x || 18.x"
  }
}